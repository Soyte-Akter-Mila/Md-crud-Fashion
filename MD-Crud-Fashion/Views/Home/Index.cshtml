<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div id="fashionCarousel" class="carousel slide shadow-sm mb-5" data-bs-ride="carousel">
                <div class="carousel-indicators">
                    <button type="button" data-bs-target="#fashionCarousel" data-bs-slide-to="0" class="active"></button>
                    <button type="button" data-bs-target="#fashionCarousel" data-bs-slide-to="1"></button>
                </div>

                <div class="carousel-inner" style="border-radius: 8px; overflow: hidden; border: 1px solid #ddd;">
                    <div class="carousel-item active">
                        <img src="~/Images/fashion-1.jpg" class="d-block w-100" alt="fashion-1" style="height: 250px; object-fit: contain; background-color: #f8f9fa;">
                        <div class="carousel-caption d-none d-md-block" style="background: rgba(0,0,0,0.6); border-radius: 5px; padding: 10px; bottom: 5%;">
                            <h5 class="mb-0">Latest Collection</h5>
                        </div>
                    </div>

                    <div class="carousel-item">
                        <img src="~/Images/fashion-2.jpg" class="d-block w-100" alt="Fashion 2" style="height: 250px; object-fit: contain; background-color: #f8f9fa;">
                        <div class="carousel-caption d-none d-md-block" style="background: rgba(0,0,0,0.6); border-radius: 5px; padding: 10px; bottom: 5%;">
                            <h5 class="mb-0">Exclusive Offer</h5>
                        </div>
                    </div>
                </div>

                <button class="carousel-control-prev" type="button" data-bs-target="#fashionCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#fashionCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
        </div>
    </div>
</div>