@model IEnumerable<MD_Crud_Fashion.Models.Product>

@{
    ViewData["Title"] = "Index";
}
<div class="container mt-4">
    <h2 class="text-center text-primary mb-4">Product List</h2>

    <div class="text-center mb-3">
        <a class="btn btn-success" asp-action="Create">+ Create New Product</a>
    </div>

    <div class="d-flex justify-content-center">
        <table class="table table-bordered table-striped w-75 shadow-lg">
            <thead class="table-dark">
                <tr>
                    <th class="text-center">
                        @Html.DisplayNameFor(model => model.ProductsName)
                    </th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">@Html.DisplayFor(modelItem => item.ProductsName)</td>
                        <td class="text-center">
                            <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.ProductsId">Edit</a>

                            <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.ProductsId">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
