@model MD_Crud_Fashion.Models.Product
@{
    ViewData["Title"] = "Edit";
}

<div class="container mt-4">
    <h2 class="text-warning mb-3">Edit Product</h2>


    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <input type="hidden" asp-for="ProductsId" />

                <div class="form-group mb-3">
                    <label asp-for="ProductsName" class="form-label fw-bold"></label>
                    <input asp-for="ProductsName" class="form-control" placeholder="Enter product name" />
                    <span asp-validation-for="ProductsName" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-pencil-square"></i> Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}