
@{
    ViewData["Title"] = "Index";
}

<h1 class="display-4 alert alert-info">Role Management</h1>

<div class="row">
    <h4 class="text-success text-center">@ViewBag.msg</h4>
</div>

<div class="row">
    <div class="col-8">
        <form asp-action="CreateRole" asp-controller="Role" method="post">
            <div class="row mb-2">
                <label class="col-form-label col-form-label-sm col-2">Role Name :</label>
                <div class="col-7">
                    <input type="text" name="userRole" class="form-control form-control-sm" placeholder="Please type role name..."/>
                </div>
                <div class="col-3">
                    <button class="btn btn-outline-primary btn-sm" type="submit">Create Role</button>
                </div>
            </div>
        </form>
    </div>
</div>